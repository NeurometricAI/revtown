# RevTown Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# =============================================================================
# Core Settings
# =============================================================================
REVTOWN_MODE=saas  # saas | self-hosted
REVTOWN_ENV=development  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# Database (Dolt)
# =============================================================================
DOLT_HOST=localhost
DOLT_PORT=3306
DOLT_DATABASE=revtown
DOLT_USER=root
DOLT_PASSWORD=

# =============================================================================
# Message Queue (Kafka)
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=revtown-api
KAFKA_SECURITY_PROTOCOL=PLAINTEXT  # PLAINTEXT | SASL_SSL

# =============================================================================
# Temporal.io
# =============================================================================
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=revtown
TEMPORAL_TASK_QUEUE=revtown-polecats

# =============================================================================
# API Settings
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Key Settings
API_KEY_PREFIX=rtk_

# =============================================================================
# LLM API (Anthropic direct, will migrate to Neurometric)
# =============================================================================
ANTHROPIC_API_KEY=

# Neurometric Gateway (for future use)
NEUROMETRIC_API_URL=https://api.neurometric.ai/v1
NEUROMETRIC_API_KEY=

# =============================================================================
# Secrets Management (Vault)
# =============================================================================
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_MOUNT_PATH=secret
VAULT_PATH_PREFIX=revtown

# =============================================================================
# Stripe Billing (SaaS mode only)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_SCALE=price_...

# =============================================================================
# External Integrations
# =============================================================================

# Twilio (The Wire - SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Vercel (Landing Pad - Landing Pages)
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# GitHub (Repo Watch)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# LinkedIn API (Social Command)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X API (Social Command)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# =============================================================================
# Frontend
# =============================================================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=RevTown

# =============================================================================
# Monitoring & Observability
# =============================================================================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=100

# =============================================================================
# Self-Hosted License (optional, for commercial self-hosted)
# =============================================================================
REVTOWN_LICENSE_KEY=
